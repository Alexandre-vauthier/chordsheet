# Firebase Configuration
# Copie ce fichier vers .env.local et remplis avec tes credentials Firebase
# https://console.firebase.google.com > Project Settings > General > Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Stripe
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des prix Stripe (Dashboard > Produits > ChordSheet Pro)
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...
# Exposés côté client pour la page pricing
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO_YEARLY=price_...

# URL de base (en prod : https://chordsheet.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Firebase Admin SDK (pour les webhooks Stripe côté serveur)
# Console Firebase > Paramètres projet > Comptes de service > Générer une clé privée
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Sentry (monitoring d'erreurs) — optionnel : sans ces variables, Sentry reste désactivé
# Crée un projet sur https://sentry.io (gratuit), puis récupère le DSN dans Project Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Pour l'upload des source maps au build (Sentry > Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=chordsheet
