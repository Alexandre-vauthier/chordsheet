rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper : vérifier si l'utilisateur est admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper : vérifier si l'utilisateur est membre d'un groupe
    function isGroupMember(groupId) {
      return request.auth != null &&
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    // Helper : vérifier si l'utilisateur a un abonnement Pro actif
    function isProUser() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)/private/subscription) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)/private/subscription).data.plan == 'pro' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)/private/subscription).data.status in ['active', 'trialing'];
    }

    // Utilisateurs - lecture/écriture pour soi-même, lecture complète pour admin
    // (le profil ne contient plus de données de facturation, voir /private/subscription)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Données privées (abonnement Stripe) - accessibles uniquement au titulaire ou à un admin
      match /private/{docId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Grilles d'accords
    match /sheets/{sheetId} {
      // Lecture : publique, propriétaire, membre du groupe, ou admin
      allow read: if resource.data.isPublic == true ||
                     (request.auth != null && request.auth.uid == resource.data.ownerId) ||
                     (request.auth != null && resource.data.groupId != null && isGroupMember(resource.data.groupId)) ||
                     isAdmin();

      // Listing (pour les requêtes sans filtre côté admin)
      allow list: if isAdmin();

      // Création : utilisateur authentifié
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid;

      // Mise à jour : propriétaire, membre du groupe (si groupId défini), admin, OU mise à jour viewCount/rating uniquement
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        isAdmin() ||
        (resource.data.groupId != null && isGroupMember(resource.data.groupId)) ||
        (resource.data.isPublic == true &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])) ||
        (resource.data.isPublic == true &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'ratingCount']))
      );

      // Suppression : propriétaire ou admin
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    // Sets (setlists) — toujours privés (owner ou membres du groupe uniquement)
    match /sets/{setId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.ownerId) ||
                     (request.auth != null && resource.data.groupId != null && isGroupMember(resource.data.groupId)) ||
                     isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.ownerId ||
                                (resource.data.groupId != null && isGroupMember(resource.data.groupId)) ||
                                isAdmin());
    }

    // Favoris (bookmarks)
    match /bookmarks/{bookmarkId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Favoris de sets
    match /setBookmarks/{bookmarkId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin();
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Bibliothèque d'accords (overrides et ajouts admin)
    match /library_chords/{docId} {
      allow read: if request.auth != null;
      allow write, delete: if isAdmin();
    }

    // Notes (ratings)
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Groupes de musique
    match /groups/{groupId} {
      // Lecture ouverte aux utilisateurs authentifiés (nécessaire pour le flux d'invitation)
      allow read: if request.auth != null;
      allow list: if isAdmin();
      // Création réservée aux comptes Pro (ou admin) - le rejoint d'un groupe existant
      // se fait via /api/groups/join (validation de l'invitation côté serveur)
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.auth.uid in request.resource.data.memberIds &&
                       (isProUser() || isAdmin());
      allow update: if request.auth != null && (
        isAdmin() ||
        // Leaders peuvent tout modifier
        (request.auth.uid in resource.data.memberIds &&
         resource.data.roles[request.auth.uid] == 'leader') ||
        // Membres peuvent modifier linkedSheetIds et activeConcert
        (request.auth.uid in resource.data.memberIds &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedSheetIds', 'activeConcert', 'updatedAt'])) ||
        // Auto-leave : membre qui se retire lui-même, et seulement lui (personne d'autre retiré/ajouté)
        (request.auth.uid in resource.data.memberIds &&
         !(request.auth.uid in request.resource.data.memberIds) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'roles', 'updatedAt']) &&
         request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1 &&
         resource.data.memberIds.hasAll(request.resource.data.memberIds))
        // Rejoindre un groupe (auto-join) n'est plus autorisé en écriture directe :
        // cela passe par /api/groups/join, qui utilise les credentials admin après
        // avoir vérifié une invitation valide (existence, expiration, quota d'usages).
      );
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    // Sessions de concert synchronisé (document ID = setId)
    match /concertSessions/{sessionId} {
      allow read, update, delete: if request.auth != null &&
                                     isGroupMember(resource.data.groupId);
      allow create: if request.auth != null &&
                      isGroupMember(request.resource.data.groupId);
    }

    // Invitations de groupe
    match /groupInvites/{token} {
      allow read: if request.auth != null;
      // Création réservée aux leaders du groupe ciblé (ou admin)
      allow create: if request.auth != null &&
                       request.resource.data.createdBy == request.auth.uid &&
                       (isAdmin() ||
                        (isGroupMember(request.resource.data.groupId) &&
                         get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.roles[request.auth.uid] == 'leader'));
      // Rejoindre un groupe passe désormais par /api/groups/join (credentials admin,
      // qui contournent ces règles) : plus besoin d'update/delete côté client.
      allow update, delete: if isAdmin();
    }
  }
}
